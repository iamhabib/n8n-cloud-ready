# Project Configuration
COMPOSE_PROJECT_NAME=n8n            # Docker Compose project name
APP_NAME=n8n                        # Application name identifier

# Host Configuration
CONTAINER_PORT=5678                 # Internal container port for the application
HOST_URL=localhost                  # Domain name for the application
PROTOCOL=http                       # Protocol to access the application (http or https)
HOST_PORT=80                        # External port to access the application
TIMEZONE=Asia/Dhaka                 # Timezone for the application